generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Operacao {
  id                           Int         @id @default(autoincrement())
  nm_agencia                   String
  cd_pessoa_pagador            String?
  nm_pessoa_pagador            String?
  nr_cpf_cnpj_raiz             String?
  nr_cpf_cnpj_pagador          String?
  nr_ctrc                      String
  id_tipo_documento            String?
  nm_pessoa_remetente          String?
  nm_cidade_origem             String?
  ds_sigla_origem              String?
  nm_pessoa_destinatario       String?
  nm_cidade_destino            String?
  ds_sigla_destino             String?
  nm_produto                   String?
  vl_peso                      Decimal?    @db.Decimal(18, 4)
  vl_tarifa                    Decimal?    @db.Decimal(18, 2)
  vl_total                     Decimal?    @db.Decimal(18, 2)
  nr_nf                        String?
  ds_placa                     String?
  nm_pessoa_matriz             String?
  nr_contrato                  String?
  nr_chave_acesso              String?
  nm_pessoa_usuario_lancamento String?
  id_tipo_ctrc                 String?
  nm_proprietario_posse_cavalo String?
  nm_motorista                 String?
  createdAt                    DateTime    @default(now())
  updatedAt                    DateTime    @updatedAt
  dt_emissao_                  DateTime
  importacaoId                 Int?
  pastaId                      Int?
  comentarios                  String?
  status                       String?
  auditorias                   Auditoria[]
  importacao                   Importacao? @relation(fields: [importacaoId], references: [id])
  pasta                        Pasta?      @relation(fields: [pastaId], references: [id])

  @@unique([nm_agencia, nr_ctrc, nr_nf, vl_total, dt_emissao_])
  @@index([nm_agencia])
  @@index([nm_produto])
  @@index([nm_motorista])
  @@index([pastaId])
  @@index([dt_emissao_])
  @@index([nm_pessoa_pagador])
  @@index([nr_ctrc])
  @@index([nr_nf])
  @@index([ds_placa])
  @@index([nm_pessoa_remetente])
  @@index([nm_pessoa_destinatario])
  @@index([nr_contrato])
  @@index([nr_chave_acesso])
  @@index([nm_pessoa_matriz])
  @@index([status])
}

model Importacao {
  id           Int        @id @default(autoincrement())
  nomeArquivo  String
  usuario      String
  qtdRegistros Int
  hashArquivo  String?
  createdAt    DateTime   @default(now())
  operacoes    Operacao[]
}

model Auditoria {
  id          Int      @id @default(autoincrement())
  tipo        String   @default("UPDATE")
  entidade    String   @default("OPERACAO")
  operacaoId  Int?
  campo       String?
  valorAntigo String?
  valorNovo   String?
  detalhes    String?
  usuario     String
  createdAt   DateTime @default(now())
  operacao    Operacao? @relation(fields: [operacaoId], references: [id], onDelete: SetNull)

  @@index([usuario])
  @@index([tipo])
  @@index([operacaoId])
}

model Pasta {
  id        Int        @id @default(autoincrement())
  nome      String     @unique
  operacoes Operacao[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}
